{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "types": ["node", "jest"],
        "verbatimModuleSyntax": false,
        "isolatedModules": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", "dist"]
}
