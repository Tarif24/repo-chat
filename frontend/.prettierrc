{
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 4,
    "useTabs": false,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "plugins": ["prettier-plugin-tailwindcss"],
    "overrides": [
        {
            "files": ".json",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ".md",
            "options": {
                "printWidth": 100,
                "proseWrap": "preserve"
            }
        }
    ]
}
