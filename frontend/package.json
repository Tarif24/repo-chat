{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3000",
        "build": "next build",
        "start": "next start",
        "lint": "eslint src/",
        "lint:fix": "eslint --fix src/",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "lint:format": "npm run lint:fix && npm run format",
        "docker:build": "docker build --build-arg NEXT_PUBLIC_API_URL=http://localhost:8080 -t repo-chat-frontend .",
        "docker:run": "docker run --name frontend -p 3000:3000 --env-file .env repo-chat-frontend",
        "docker:stop": "docker stop frontend",
        "docker:rm": "docker rm -f frontend"
    },
    "dependencies": {
        "lucide-react": "^0.577.0",
        "next": "16.1.7",
        "react": "19.2.3",
        "react-dom": "19.2.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.1.7",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.6.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4",
        "typescript": "^5",
        "typescript-eslint": "^8.61.0"
    }
}
